<div class="profile-container">
  <h1>User Profile</h1>

  <div class="profile-card">
    <p><strong>Name:</strong> <%= @user.name %></p>
    <p><strong>Email:</strong> <%= @user.email %></p>
    <p><strong>DOB:</strong> <%= @user.dob %></p>
    <p><strong>Phone:</strong> <%= @user.phone %></p>
    <p><strong>Address:</strong> <%= @user.address %></p>
  </div>

  <h3>Add More Profile Fields</h3>

  <div class="form-card">
    <%= form_with model: ProfileField.new, url: "/profile_fields", method: :post do |f| %>
      <div class="form-group">
        <%= f.label :key, "Field Name" %><br>
        <%= f.text_field :key %>
      </div>

      <div class="form-group">
        <%= f.label :value, "Value" %><br>
        <%= f.text_field :value %>
      </div>

      <%= f.submit "Add Field", class: "btn" %>
    <% end %>
  </div>

  <h3>Additional Profile Fields</h3>

  <% @user.profile_fields.each_with_index do |field, index| %>
    <div class="field-row">
      <div class="field-left">
        <span class="field-number"><%= index + 1 %>.</span>
        <span class="field-key"><%= field.key %></span>
      </div>
      <span class="field-value"><%= field.value %></span>
    </div>
  <% end %><br>

  <%= form_with model: @user, url: profile_path, method: :patch do |f| %>
    <h3>Additional Nested Fields</h3>
    <%= f.fields_for :profile_fields do |pf| %>
      <div class="field-box">
        <%= pf.label :key %>
        <%= pf.text_field :key %>
        <%= pf.label :value %>
        <%= pf.text_field :value %>
        <%= pf.check_box :_destroy %>
        <%= pf.label :_destroy, "Remove" %>
      </div>
    <% end %>
    <%= f.submit %> 
  <% end %>

  </div>
</div>


<p>Find me in app/views/profiles/show.html.erb</p>
