<section class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
  <div class="card shadow p-4" style="width: 500px;">

  <h2 class="text-center mb-4">Create New Post</h2>

    <%= link_to "← Back to Posts", posts_path, class: "btn btn-secondary mb-3" %>

    <%= form_with(model: @post, local: true) do |f| %>

      <div class="mb-3">
        <%= f.label :title, class: "form-label" %>
        <%= f.text_field :title, class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= f.label :content, class: "form-label" %>
        <%= f.text_area :content, class: "form-control", rows: 4 %>
      </div>

      <div class="text-center">
      <%= f.submit "Create Post", class: "btn btn-success w-100" %>
      </div>

    <% end %>

  </div>
</section>